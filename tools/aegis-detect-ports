#!/bin/bash

###############################################################################
#                  MTS Aegis — Hardware Port Detection Tool                  #
#                       Renato Oliveira / MT-Solutions                       #
#                                                                             #
#  Identifies the stable PCI path for each physical USB port and writes      #
#  /etc/aegis/ports.conf so all Aegis scripts can resolve devices reliably.  #
#                                                                             #
#  Usage:                                                                     #
#    sudo aegis-detect-ports            — interactive (default)              #
#    sudo aegis-detect-ports --auto     — auto-detect, no prompts            #
#    sudo aegis-detect-ports --show     — print current config and exit      #
###############################################################################

set -uo pipefail

CONF_DIR="/etc/aegis"
CONF_FILE="${CONF_DIR}/ports.conf"
AUTO=0
SHOW=0

# ── Colour helpers ────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'
YELLOW='\033[1;33m'; BOLD='\033[1m'; RESET='\033[0m'

info()   { echo -e "${CYAN}[AEGIS]${RESET} $*"; }
ok()     { echo -e "${GREEN}[  OK  ]${RESET} $*"; }
warn()   { echo -e "${YELLOW}[ WARN ]${RESET} $*"; }
fail()   { echo -e "${RED}[ FAIL ]${RESET} $*"; exit 1; }
header() { echo -e "\n${BOLD}${CYAN}━━━  $*  ━━━${RESET}\n"; }

# ── Argument parsing ──────────────────────────────────────────────────────────
for arg in "$@"; do
    case "$arg" in
        --auto) AUTO=1 ;;
        --show) SHOW=1 ;;
        --help|-h)
            echo "Usage: sudo aegis-detect-ports [--auto | --show | --help]"
            echo "  (no args)  Interactive guided port detection"
            echo "  --auto     Detect automatically without prompts"
            echo "  --show     Print current port configuration and exit"
            exit 0 ;;
    esac
done

# ── Root check ────────────────────────────────────────────────────────────────
[ "$(id -u)" -eq 0 ] || fail "Must run as root: sudo aegis-detect-ports"

# ── --show mode ───────────────────────────────────────────────────────────────
if [ "$SHOW" -eq 1 ]; then
    if [ ! -f "$CONF_FILE" ]; then
        warn "No port configuration found at ${CONF_FILE}"
        warn "Run: sudo aegis-detect-ports"
        exit 1
    fi
    echo ""
    echo -e "${BOLD}Current Aegis port configuration:${RESET}"
    echo -e "  File: ${CONF_FILE}"
    echo ""
    # shellcheck source=/etc/aegis/ports.conf
    source "$CONF_FILE"
    echo -e "  Port A (Type-A / scan):   ${BOLD}${AEGIS_PORT_A:-NOT SET}${RESET}"
    SYMLINK_A="/dev/disk/by-path/${AEGIS_PORT_A}"
    if [ -L "$SYMLINK_A" ]; then
        DEV_A=$(readlink -f "$SYMLINK_A")
        echo -e "                            -> ${DEV_A} ${GREEN}(connected)${RESET}"
    else
        echo -e "                            -> ${YELLOW}(nothing connected)${RESET}"
    fi
    echo ""
    echo -e "  Port C (Type-C / clean):  ${BOLD}${AEGIS_PORT_C:-NOT SET}${RESET}"
    SYMLINK_C="/dev/disk/by-path/${AEGIS_PORT_C}"
    if [ -L "$SYMLINK_C" ]; then
        DEV_C=$(readlink -f "$SYMLINK_C")
        echo -e "                            -> ${DEV_C} ${GREEN}(connected)${RESET}"
    else
        echo -e "                            -> ${YELLOW}(nothing connected)${RESET}"
    fi
    echo ""
    exit 0
fi

# ── Helper: list current USB block device PCI paths ──────────────────────────
list_usb_paths() {
    # Returns lines of: /dev/disk/by-path/<pci-path>  ->  /dev/sdX
    # Filtered to USB-attached block devices only
    find /dev/disk/by-path/ -maxdepth 1 -type l 2>/dev/null \
        | grep -E 'usb.*scsi' | grep -v '\-part' \
        | while read -r link; do
            target=$(readlink -f "$link")
            id="${link#/dev/disk/by-path/}"
            echo "$id  ->  $target"
        done
}

# ── Helper: snapshot current USB PCI IDs ─────────────────────────────────────
snapshot_ids() {
    find /dev/disk/by-path/ -maxdepth 1 -type l 2>/dev/null \
        | grep -E 'usb.*scsi' | grep -v '\-part' \
        | xargs -I{} basename {} \
        | sort
}

# ── Helper: wait for a NEW device to appear, return its PCI ID ────────────────
wait_for_new_device() {
    local label="$1"
    local before_file="$2"
    local timeout=60
    local elapsed=0
    local spinner=('|' '/' '-' '\\')
    local si=0

    while [ "$elapsed" -lt "$timeout" ]; do
        local current
        current=$(snapshot_ids)
        local new_id
        new_id=$(comm -13 <(sort "$before_file") <(echo "$current" | sort) | head -n1)

        if [ -n "$new_id" ]; then
            echo "$new_id"
            return 0
        fi

        printf "\r  ${spinner[$si]} Waiting for %s... (%ds)" "$label" "$elapsed"
        si=$(( (si + 1) % 4 ))
        sleep 1
        elapsed=$(( elapsed + 1 ))
    done

    printf "\r  %-50s\n" ""   # clear spinner line
    return 1
}

# ═════════════════════════════════════════════════════════════════════════════
header "MTS AEGIS — Port Detection"

mkdir -p "$CONF_DIR"

# ── AUTO MODE ─────────────────────────────────────────────────────────────────
if [ "$AUTO" -eq 1 ]; then
    info "Auto-detect mode: scanning current USB devices..."
    echo ""

    mapfile -t usb_ids < <(snapshot_ids)

    if [ "${#usb_ids[@]}" -lt 2 ]; then
        fail "Auto-detect requires at least 2 USB storage devices plugged in. Found ${#usb_ids[@]}. Use interactive mode instead."
    fi

    PORT_A="${usb_ids[0]}"
    PORT_C="${usb_ids[1]}"

    echo -e "  Detected ${#usb_ids[@]} USB device(s):"
    for id in "${usb_ids[@]}"; do
        dev=$(readlink -f "/dev/disk/by-path/${id}" 2>/dev/null || echo "?")
        echo -e "    ${id}  ->  ${dev}"
    done
    echo ""
    warn "Auto-assign: Port A = ${usb_ids[0]}"
    warn "Auto-assign: Port C = ${usb_ids[1]}"
    warn "If these are wrong, re-run without --auto for guided detection."
    echo ""

# ── INTERACTIVE MODE ──────────────────────────────────────────────────────────
else
    echo -e "  This tool identifies which physical USB port is Port A (Type-A, scan)"
    echo -e "  and which is Port C (Type-C, clean destination)."
    echo -e ""
    echo -e "  You will be prompted to plug a USB drive into each port."
    echo -e "  Use any drive — it will NOT be modified."
    echo -e ""

    # ── Step 1: Detect Port A ────────────────────────────────────────────────
    header "STEP 1 of 2 — Detect Port A (Type-A, the scan port)"

    # Make sure nothing is plugged in first
    echo -e "  ${YELLOW}Please UNPLUG all USB storage devices now.${RESET}"
    echo -e "  Press ENTER when all USB drives are removed."
    read -r

    # Snapshot the empty state
    BEFORE_FILE=$(mktemp /tmp/aegis_before.XXXXXX)
    snapshot_ids > "$BEFORE_FILE"

    echo ""
    echo -e "  ${CYAN}Now plug a USB drive into the ${BOLD}TYPE-A (rectangular)${RESET}${CYAN} port.${RESET}"
    echo ""

    PORT_A=$(wait_for_new_device "Port A" "$BEFORE_FILE")
    if [ $? -ne 0 ] || [ -z "$PORT_A" ]; then
        rm -f "$BEFORE_FILE"
        fail "Timed out waiting for Port A. Check the drive and try again."
    fi
    printf "\r  %-60s\n" ""

    DEV_A=$(readlink -f "/dev/disk/by-path/${PORT_A}" 2>/dev/null || echo "unknown")
    ok "Port A detected: ${BOLD}${PORT_A}${RESET}"
    ok "               -> ${DEV_A}"
    echo ""

    # ── Step 2: Detect Port C ────────────────────────────────────────────────
    header "STEP 2 of 2 — Detect Port C (Type-C, the clean destination port)"

    echo -e "  ${YELLOW}Now UNPLUG the drive from Port A.${RESET}"
    echo -e "  Press ENTER when Port A is empty."
    read -r

    # Re-snapshot with Port A empty
    snapshot_ids > "$BEFORE_FILE"

    echo ""
    echo -e "  ${CYAN}Now plug a USB drive into the ${BOLD}TYPE-C (oval)${RESET}${CYAN} port.${RESET}"
    echo ""

    PORT_C=$(wait_for_new_device "Port C" "$BEFORE_FILE")
    if [ $? -ne 0 ] || [ -z "$PORT_C" ]; then
        rm -f "$BEFORE_FILE"
        fail "Timed out waiting for Port C. Check the drive and try again."
    fi
    printf "\r  %-60s\n" ""

    DEV_C=$(readlink -f "/dev/disk/by-path/${PORT_C}" 2>/dev/null || echo "unknown")
    ok "Port C detected: ${BOLD}${PORT_C}${RESET}"
    ok "               -> ${DEV_C}"
    echo ""

    rm -f "$BEFORE_FILE"

    # ── Confirm ──────────────────────────────────────────────────────────────
    echo -e "  ${BOLD}Summary:${RESET}"
    echo -e "    Port A (scan)     : ${CYAN}${PORT_A}${RESET}"
    echo -e "    Port C (clean)    : ${CYAN}${PORT_C}${RESET}"
    echo ""

    if [ "$PORT_A" = "$PORT_C" ]; then
        fail "Port A and Port C resolved to the same ID. The same drive was detected twice. Try again."
    fi

    echo -e "  Write this configuration to ${CONF_FILE}? [Y/n] "
    read -r confirm
    case "${confirm,,}" in
        n|no) fail "Aborted by user. Nothing written."; exit 1 ;;
    esac
fi

# ── Write config file ─────────────────────────────────────────────────────────
cat > "$CONF_FILE" << CONF
# MTS Aegis — Hardware Port Configuration
# Generated by: aegis-detect-ports
# Date: $(date)
#
# AEGIS_PORT_A: Port A (Type-A, rectangular) — the SCAN / dirty port
# AEGIS_PORT_C: Port C (Type-C, oval)        — the CLEAN / destination port
#
# To reconfigure: sudo aegis-detect-ports
# To view current: sudo aegis-detect-ports --show

AEGIS_PORT_A="${PORT_A}"
AEGIS_PORT_C="${PORT_C}"
CONF

chmod 644 "$CONF_FILE"
ok "Configuration written to ${CONF_FILE}"

# ── Reload webui.py so changes take effect without full restart ───────────────
if systemctl is-active --quiet aegis-webui 2>/dev/null; then
    info "Restarting aegis-webui to apply new port configuration..."
    systemctl restart aegis-webui
    ok "aegis-webui restarted."
fi

echo ""
echo -e "${GREEN}${BOLD}  Port configuration complete. Aegis will now use these ports.${RESET}"
echo ""
